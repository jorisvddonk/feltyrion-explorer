{"componentChunkName":"component---src-templates-planet-info-tsx","path":"/planets/UEGYE","result":{"data":{"planet":{"id":"planet_UEGYE","data":{"name":"UEGYE","index":"22","x":22364336,"y":-7906996,"z":48257710},"childrenGuideEntry":[{"data":{"text":"A GREY DUSTY MOON, THE FIRST OF THE EIGHTH PLANET. SURPRISINGLY, THERE"}},{"data":{"text":"ARE FEW CRATERS. THE COLORS ARE USUALLY SHADES OF YELLOWISH GREEN, AND"}},{"data":{"text":"THE SURFACE FEATURES ARE AVERAGE."}},{"data":{"text":"(NOTES BY JEFF KEMP EPOC 6011:631:920)"}}]}},"pageContext":{"slug":"/planets/UEGYE"}}}