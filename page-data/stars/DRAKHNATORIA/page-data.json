OUSE"}},{"data":{"text":"OF THE TWO STRANGE FELISIAN WORLDS WE HAVE FOUND HERE, AND ALSO"}},{"data":{"text":"BECOUSE OF THE PLANET DRAKHNATORIA PRIME."}},{"data":{"text":" WE NOW HAVE TO LEAVE THIS SYSTEM TO CONTINIUE OUR SEARCH FOR THE"}},{"data":{"text":"LEGENDARY WORLD OF ANTYREN."}},{"data":{"text":"CONCLUSION: THIS SYSTEM IS A SYSTEM OF THE ANCIENTS, AND IS"}},{"data":{"text":"DEFFINENTLY WORTH A RE-VISIT BY OTHER EXPLORERS."}},{"data":{"text":"VIMANA-DRIVE ENGAGED, PREPARE FOR VIMANA-LEAP..."}},{"data":{"text":"(STARGAZER. EPOC 6011; 585.425.400)"}}],"childrenPlanet":[{"id":"planet_NEAR","data":{"name":"NEAR","index":"01"},"fields":{"slug":"/planets/NEAR"}},{"id":"planet_ATORIA","data":{"name":"ATORIA","index":"02"},"fields":{"slug":"/planets/ATORIA"}},{"id":"planet_FITHIP","data":{"name":"FITHIP","index":"03"},"fields":{"slug":"/planets/FITHIP"}},{"id":"planet_GASIOUS","data":{"name":"GASIOUS","index":"04"},"fields":{"slug":"/planets/GASIOUS"}},{"id":"planet_SMYRTYORIA","data":{"name":"SMYRTYORIA","index":"05"},"fields":{"slug":"/planets/SMYRTYORIA"}},{"id":"planet_MESSAGE BEARER","data":{"name":"MESSAGE BEARER","index":"06"},"fields":{"slug":"/planets/MESSAGE BEARER"}},{"id":"planet_RINGORIA","data":{"name":"RINGORIA","index":"07"},"fields":{"slug":"/planets/RINGORIA"}},{"id":"planet_THUKTUN FLISHITHY","data":{"name":"THUKTUN FLISHITHY","index":"08"},"fields":{"slug":"/planets/THUKTUN FLISHITHY"}},{"id":"planet_FARWORLD","data":{"name":"FARWORLD","index":"09"},"fields":{"slug":"/planets/FARWORLD"}},{"id":"planet_...NOR HERE...","data":{"name":"...NOR HERE...","index":"10"},"fields":{"slug":"/planets/...NOR HERE"}},{"id":"planet_URTYORIA","data":{"name":"URTYORIA","index":"11"},"fields":{"slug":"/planets/URTYORIA"}},{"id":"planet_0","data":{"name":"0","index":"12"},"fields":{"slug":"/planets/0"}},{"id":"planet_DUSTY, CREATERIZED..","data":{"name":"DUSTY, CREATERIZED..","index":"13"},"fields":{"slug":"/planets/DUSTY, CREATERIZED"}},{"id":"planet_NADA","data":{