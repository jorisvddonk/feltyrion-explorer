 HAVE FOUND LIFE. THIS"}},{"data":{"text":"IS GOOD, BUT THE REAL HIGHLIGHT HERE IS THE FACT THAT THE TRUNKS OF THE"}},{"data":{"text":"TREES THERE WERE TRANSPARENT! IT WAS AMAZING, AND IT MAKES THIS STAR"}},{"data":{"text":"WORTH A VISIT FROM VIRTUALLY ANYWHERE YOU MAY BE. THE MOON'S NAME IS"}},{"data":{"text":"'DEMENTED' FROM THE VERY FIRST IMPRESSION I GOT UPON SEEING IT FROM"}},{"data":{"text":"SPACE, AND I MUST SAY IT HAS LIVED UP TO ITS NAME. THE LOCATION OF THE"}},{"data":{"text":"SEE-THROUGH TREES IS WRITTEN IN THE NOTES OF THE MOON ITSELF. THIS HAS"}},{"data":{"text":"TURNED OUT TO BE A WONDEROUS SYSTEM. --EKA"}},{"data":{"text":"HAH! IT SEEMS SOMEONE HAD NAMED THE STAR BEFORE I UPDATED. --EKA"}}],"childrenPlanet":[{"id":"planet_GURIELS","data":{"name":"GURIELS","index":"01"},"fields":{"slug":"/planets/GURIELS"}},{"id":"planet_VRUNARTA","data":{"name":"VRUNARTA","index":"02"},"fields":{"slug":"/planets/VRUNARTA"}},{"id":"planet_ALIURTREN","data":{"name":"ALIURTREN","index":"03"},"fields":{"slug":"/planets/ALIURTREN"}},{"id":"planet_GRAITION","data":{"name":"GRAITION","index":"04"},"fields":{"slug":"/planets/GRAITION"}},{"id":"planet_ANGELIDRAN","data":{"name":"ANGELIDRAN","index":"05"},"fields":{"slug":"/planets/ANGELIDRAN"}},{"id":"planet_LIQUID METAL","data":{"name":"LIQUID METAL","index":"06"},"fields":{"slug":"/planets/LIQUID METAL"}},{"id":"planet_COFFEE","data":{"name":"COFFEE","index":"07"},"fields":{"slug":"/planets/COFFEE"}},{"id":"planet_SAPPHIRE CROWN","data":{"name":"SAPPHIRE CROWN","index":"09"},"fields":{"slug":"/planets/SAPPHIRE CROWN"}},{"id":"planet_SKELETON OF DUST","data":{"name":"SKELETON OF DUST","index":"10"},"fields":{"slug":"/planets/SKELETON OF DUST"}},{"id":"planet_ENDLESS BOIL","data":{"name":"ENDLESS BOIL","index":"11"},"fields":{"slug":"/planets/ENDLESS BOIL"}},{"id":"planet_CORPSE OF DUST","data":{"name":"CORPSE OF DUST","index":"12"},"fields":{"slug":"/planets/CORPSE OF DUST"}},{"id":"planet_NEON PURPLE","data":{"name":"NEON PU