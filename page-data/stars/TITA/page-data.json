Y CHANGED MY PLANS. LEJANIA MEANS 'REMOTE PLACE'. PLEASE. LEOW."}},{"data":{"text":"I, MURRMURR, HAVE FOUND AND LABELLED THE 12TH PLANET 'LEJANIA'."}},{"data":{"text":"(AS PER THE PREVIOUS STARDRIFTER'S WISH)."}},{"data":{"text":"IT WAS EASY TO FIND THE PLANET. I JUST WENT TO ONE OF IT'S MOONS, AND"}},{"data":{"text":"FROM THERE IT WAS A SHORT HOP TO THE PLANET."}},{"data":{"text":"(NOTES BY MURRMURR EPOC 6011:608.339)"}}],"childrenPlanet":[{"id":"planet_INFIERNILLO","data":{"name":"INFIERNILLO","index":"01"},"fields":{"slug":"/planets/INFIERNILLO"}},{"id":"planet_ANULAR","data":{"name":"ANULAR","index":"02"},"fields":{"slug":"/planets/ANULAR"}},{"id":"planet_NUBLAR","data":{"name":"NUBLAR","index":"03"},"fields":{"slug":"/planets/NUBLAR"}},{"id":"planet_VERDEBELLA","data":{"name":"VERDEBELLA","index":"04"},"fields":{"slug":"/planets/VERDEBELLA"}},{"id":"planet_DESERTICA","data":{"name":"DESERTICA","index":"05"},"fields":{"slug":"/planets/DESERTICA"}},{"id":"planet_INOSPITA","data":{"name":"INOSPITA","index":"06"},"fields":{"slug":"/planets/INOSPITA"}},{"id":"planet_ARIDA","data":{"name":"ARIDA","index":"07"},"fields":{"slug":"/planets/ARIDA"}},{"id":"planet_QUARITZIA","data":{"name":"QUARITZIA","index":"08"},"fields":{"slug":"/planets/QUARITZIA"}},{"id":"planet_ABANDONO","data":{"name":"ABANDONO","index":"10"},"fields":{"slug":"/planets/ABANDONO"}},{"id":"planet_OLVIDO","data":{"name":"OLVIDO","index":"11"},"fields":{"slug":"/planets/OLVIDO"}},{"id":"planet_LEJANIA","data":{"name":"LEJANIA","index":"12"},"fields":{"slug":"/planets/LEJANIA"}}]}},"pageContext":{"slug":"/stars/TITA"}}}